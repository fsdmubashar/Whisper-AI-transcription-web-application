# ══════════════════════════════════════════════════════
#  Environment Variables
#  Is file ko copy karo: cp .env.example .env
#  .env ko KABHI Git mein push mat karo!
# ══════════════════════════════════════════════════════

# ── Whisper Settings ──────────────────────────────────
# Options: tiny | base | small | medium | large
# tiny   → sabse fast, kam accurate (CPU ke liye)
# base   → balanced (recommended for CPU)
# medium → zyada accurate, slow
# large  → best accuracy, GPU zaroori
WHISPER_MODEL_SIZE=base

# ── Server Settings ───────────────────────────────────
PORT=8000
LOG_LEVEL=info
GUNICORN_WORKERS=2

# ── Database ──────────────────────────────────────────
# SQLite (default, koi setup nahi chahiye)
DATABASE_URL=sqlite:///./transcriptions.db

# PostgreSQL ke liye (production recommended):
# DATABASE_URL=postgresql://user:password@localhost:5432/whisper_db
